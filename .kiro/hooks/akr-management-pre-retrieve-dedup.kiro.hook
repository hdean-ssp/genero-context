{
  "enabled": false,
  "name": "Deduplication Check Before Retrieval",
  "description": "Disabled — retrieval is always safe and does not need a pre-check. Deduplication is handled by the pre-commit hook.",
  "version": "1",
  "when": {
    "type": "preToolUse",
    "toolTypes": ["shell"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "This hook is disabled."
  }
}
