{
  "enabled": true,
  "name": "AKR Post-Commit Validation",
  "description": "After a shell command that called commit_knowledge.sh, validates the committed knowledge.",
  "version": "1",
  "when": {
    "type": "postToolUse",
    "toolTypes": ["shell"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "If the shell command that just ran called commit_knowledge.sh or merge_knowledge.sh, run a quick validation:\n\n```bash\nbash ~/.kiro/scripts/validate_knowledge.sh\n```\n\nIf validation fails, fix the issue and re-commit. If the command that just ran was NOT an AKR commit, skip this check entirely and proceed."
  }
}
